# ============================================
# 生产环境配置（复制为 .env 后修改）
# 本地开发可只填 GITHUB_* 部分，其余用默认值
# ============================================

# 必填：随机字符串，不要用默认值
JWT_SECRET=请换成随机长字符串

# GitHub OAuth — 建议生产环境单独建一个 OAuth App
# https://github.com/settings/developers
GITHUB_CLIENT_ID=你的生产环境ClientID
GITHUB_CLIENT_SECRET=你的生产环境ClientSecret

# 你的网站地址（有域名用 https + 域名，只有 IP 用 http + IP）
FRONTEND_URL=https://你的域名.com
GITHUB_CALLBACK_URL=https://你的域名.com/api/auth/github/callback

# 若暂时只有 IP、无域名（示例）：
# FRONTEND_URL=http://114.55.42.204
# GITHUB_CALLBACK_URL=http://114.55.42.204/api/auth/github/callback

# AI 文章摘要（通义千问 OpenAI 兼容模式，也支持 OpenAI / DeepSeek 等）
# 通义：https://dashscope.console.aliyun.com/
AI_API_KEY=你的API密钥
AI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-turbo

# OpenAI 示例：
# AI_API_BASE=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
